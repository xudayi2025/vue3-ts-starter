        "@vue/cli-plugin-eslint": "~5.0.0-beta.3",
        "@vue/cli-plugin-typescript": "~5.0.0-beta.3",
        "@vue/cli-service": "~5.0.0-beta.3",
        "@vue/compiler-sfc": "^3.0.4",
        "@vue/eslint-config-typescript": "^7.0.0",
